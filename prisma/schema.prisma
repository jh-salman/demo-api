// demo-api — v2-admin parity (Postgres + file fallback via store).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single-tenant row: full `SalonxV2AdminConfig` JSON.
model SalonxBuildConfig {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt
  webProjectionAt DateTime @default(now())
  publishedPayload Json?
}

/// Calendar appointments (`/api/appointments`).
model SalonxAppointment {
  id         String   @id @default(cuid())
  clientName String
  service    String   @default("")
  startAt    DateTime
  endAt      DateTime
  color      String   @default("#3b82f6")
  price      Float    @default(0)
  notes      String   @default("")
  seriesId   String?
  staffId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([staffId])
}

/// Parked + waitlist toolbar rows for salonx-web-v2 (`/api/calendar-toolbar`).
model SalonxCalendarToolbar {
  id              String   @id @default("default")
  parkedFromDrag  Json
  toolbarEvents   Json
  updatedAt       DateTime @updatedAt
}

/// Client picker list (`/api/clients`).
model SalonxClientCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Staff roster for calendar day columns (`/api/staff`).
model SalonxStaffCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Service picker list (`/api/service-catalog`).
model SalonxServiceCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Per-client consultation notes + LOOK photos (`/api/client-consultation/:clientKey`).
model SalonxClientConsultation {
  clientKey String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/// Per-appointment checkout queue + rates (`/api/appointment-visit/:appointmentId`).
model SalonxAppointmentVisit {
  appointmentId String   @id
  payload       Json
  updatedAt     DateTime @updatedAt
}

/// Product picker list (`/api/product-catalog`).
model SalonxProductCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

// ── RAMP runtime (salonx-web-v2 capture → build → ship) ──────────────────────

/// One RAMP item = queue row + build doc in a single record (`/api/ramp/posts`).
/// status: queued | building | generated | shipped | dismissed
/// source: capture | station | s5
model RampPost {
  id              String    @id @default(cuid())
  salonId         String    @default("default")

  clientId        String?
  clientName      String
  clientSub       String?
  clientEmoji     String?   @default("🧑")
  stylistId       String?

  source          String    @default("capture")
  status          String    @default("queued")

  /// string[] of uploaded capture URLs.
  capturedImages  Json      @default("[]")
  /// string[] of generated/composed image URLs (latest last).
  generatedImages Json      @default("[]")
  /// Selected hero image URL (usually one of capturedImages).
  heroImage       String?

  caption         String    @default("")
  type            String    @default("Curiosity")
  tags            Json      @default("[]")
  links           Json      @default("[]")
  backgroundId    String    @default("bg1")

  genState        String    @default("idle")
  shipMode        String?
  shippedAt       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([salonId, status, createdAt])
  @@index([clientId])
  @@map("RampPost")
}
