// demo-api — v2-admin parity (Postgres + file fallback via store).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single-tenant row: full `SalonxV2AdminConfig` JSON.
model SalonxBuildConfig {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt
  webProjectionAt DateTime @default(now())
  publishedPayload Json?
}

/// Calendar appointments (`/api/appointments`).
model SalonxAppointment {
  id         String   @id @default(cuid())
  clientName String
  service    String   @default("")
  startAt    DateTime
  endAt      DateTime
  color      String   @default("#3b82f6")
  price      Float    @default(0)
  notes      String   @default("")
  seriesId   String?
  staffId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([staffId])
}

/// Parked + waitlist toolbar rows for salonx-web-v2 (`/api/calendar-toolbar`).
model SalonxCalendarToolbar {
  id              String   @id @default("default")
  parkedFromDrag  Json
  toolbarEvents   Json
  updatedAt       DateTime @updatedAt
}

/// Client picker list (`/api/clients`).
model SalonxClientCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Staff roster for calendar day columns (`/api/staff`).
model SalonxStaffCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Service picker list (`/api/service-catalog`).
model SalonxServiceCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Per-client consultation notes + LOOK photos (`/api/client-consultation/:clientKey`).
model SalonxClientConsultation {
  clientKey String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/// Per-appointment checkout queue + rates (`/api/appointment-visit/:appointmentId`).
model SalonxAppointmentVisit {
  appointmentId String   @id
  payload       Json
  updatedAt     DateTime @updatedAt
}

/// Product picker list (`/api/product-catalog`).
model SalonxProductCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// RAMP demo posts — Client Care Card + public `/p/:token` flow.
model RampDemoPost {
  id             String   @id @default(cuid())
  token          String   @unique
  brandSlug      String
  recipientPhone String
  recipientName  String   @default("")
  stylistName    String   @default("")
  products       Json     @default("[]")
  status         String   @default("care_sent")
  sourceType     String   @default("client_care")
  careCardUrl    String?
  compositeUrl   String?
  caption        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  visits RampVisit[]
  assets RampSharedAsset[]

  @@index([recipientPhone])
  @@index([brandSlug])
}

/// RAMP visit / funnel events (landing, copy, share).
model RampVisit {
  id           String   @id @default(cuid())
  token        String
  eventType    String
  metadataJson Json?
  createdAt    DateTime @default(now())
  post         RampDemoPost @relation(fields: [token], references: [token], onDelete: Cascade)

  @@index([token])
}

/// Client selfie / shared media for RAMP artifact.
model RampSharedAsset {
  id            String   @id @default(cuid())
  token         String
  brandSlug     String   @default("")
  source        String   @default("web_upload")
  phone         String?
  mediaUrl      String?
  cloudinaryUrl String?
  createdAt     DateTime @default(now())
  post          RampDemoPost @relation(fields: [token], references: [token], onDelete: Cascade)

  @@index([token])
}
