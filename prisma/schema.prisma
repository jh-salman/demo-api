// demo-api — v2-admin parity (Postgres + file fallback via store).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single-tenant row: full `SalonxV2AdminConfig` JSON.
model SalonxBuildConfig {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt
  webProjectionAt DateTime @default(now())
  publishedPayload Json?
}

/// Calendar appointments (`/api/appointments`).
model SalonxAppointment {
  id         String   @id @default(cuid())
  clientName String
  service    String   @default("")
  startAt    DateTime
  endAt      DateTime
  color      String   @default("#3b82f6")
  price      Float    @default(0)
  notes      String   @default("")
  seriesId   String?
  staffId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([staffId])
}

/// Parked + waitlist toolbar rows for salonx-web-v2 (`/api/calendar-toolbar`).
model SalonxCalendarToolbar {
  id              String   @id @default("default")
  parkedFromDrag  Json
  toolbarEvents   Json
  updatedAt       DateTime @updatedAt
}

/// Client picker list (`/api/clients`).
model SalonxClientCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Staff roster for calendar day columns (`/api/staff`).
model SalonxStaffCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Service picker list (`/api/service-catalog`).
model SalonxServiceCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

/// Per-client consultation notes + LOOK photos (`/api/client-consultation/:clientKey`).
model SalonxClientConsultation {
  clientKey String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/// Per-appointment checkout queue + rates (`/api/appointment-visit/:appointmentId`).
model SalonxAppointmentVisit {
  appointmentId String   @id
  payload       Json
  updatedAt     DateTime @updatedAt
}

/// Product picker list (`/api/product-catalog`).
model SalonxProductCatalog {
  id        String   @id @default("default")
  items     Json
  updatedAt DateTime @updatedAt
}

// ── RAMP V3 runtime (salonx-web-v2 Build → Ship) ─────────────────────────────

/// Capture → S1 queue (`GET/POST /api/ramp/visits`).
model RampVisit {
  id             String   @id @default(cuid())
  salonId        String   @default("default")
  stylistId      String?
  clientId       String?
  clientName     String
  clientSub      String?
  clientEmoji    String?
  status         String   @default("queued")
  captureAssetId String?
  postId         String?  @unique
  queuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  post RampDemoPost? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([salonId, status, queuedAt])
  @@map("RampVisit")
}

/// Full post document (`GET/PATCH /api/ramp/posts/:id`).
model RampDemoPost {
  id               String    @id @default(cuid())
  salonId          String    @default("default")
  stylistId        String?
  target           Json      @default("{}")
  caption          String    @default("")
  type             String    @default("Curiosity")
  tags             Json      @default("[]")
  links            Json      @default("[]")
  heroId           String    @default("s0")
  heroTab          String    @default("ramp")
  captureAssetId   String?
  capturePlacement Json?
  backgrounds      Json      @default("[]")
  backgroundIndex  Int       @default(0)
  templateId       String    @default("tem1")
  posterByTemplate Json      @default("{}")
  dirty            Json      @default("{}")
  genState         String    @default("idle")
  composedAssetId  String?
  shipMode         String?
  shippedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  visit RampVisit?

  @@index([salonId, genState])
  @@map("RampDemoPost")
}

/// Media library (`GET/POST /api/ramp/assets`).
model RampSharedAsset {
  id        String   @id @default(cuid())
  salonId   String   @default("default")
  clientId  String?
  postId    String?
  visitId   String?
  kind      String
  source    String   @default("upload")
  url       String
  thumbUrl  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([salonId, clientId, kind])
  @@index([postId])
  @@index([visitId])
  @@map("RampSharedAsset")
}
