NODE_ENV=development
PORT=4000
# Comma-separated SPA origins, or * (default). Example:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# Required for Prisma migrate / appointments + persisted config in Postgres.
# Optional at runtime for file-backed config only (store falls back to data/*.json).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/demo_api?schema=public"

# Same role as v2-admin: absolute URLs in config JSON for salonx-web-v2.
# PUBLIC_SITE_URL=http://localhost:4000

# Optional uploads (first match wins): Cloudinary → Vercel Blob → local `public/uploads`.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# BLOB_READ_WRITE_TOKEN=

# salonx-web-v2 (production): VITE_V2_ADMIN_URL=https://demo-api-k8p3.onrender.com
# v2-admin: NEXT_PUBLIC_SALONX_API_ORIGIN=https://demo-api-k8p3.onrender.com
# Local dev: http://localhost:4000

# --- salonx-web-v2 (Vite dev) — same machine, proxy to demo-api ---
# In salonx-web-v2/.env: VITE_DEV_USE_DEMO_API=true
# Optional if demo-api is not on :4000: VITE_DEMO_API_PROXY_TARGET=http://127.0.0.1:4000
