NODE_ENV=development
PORT=4000
# Comma-separated SPA origins, or * (default). Example:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# Required for Prisma migrate / appointments + persisted config in Postgres.
# Optional at runtime for file-backed config only (store falls back to data/*.json).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/demo_api?schema=public"

# Same role as v2-admin: absolute URLs in config JSON for salonx-web-v2.
# PUBLIC_SITE_URL=http://localhost:4000

# Optional uploads (first match wins): Cloudinary → Vercel Blob → local `public/uploads`.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# BLOB_READ_WRITE_TOKEN=

# --- SUPER RAMP (API-only: capture → OpenAI → SMS/MMS → POST IT) ---
#
# CREDENTIAL MAP — where each value comes from:
# OPENAI_API_KEY        → https://platform.openai.com/api-keys
# OPENAI_IMAGE_MODEL    → optional (default gpt-image-1)
# CLOUDINARY_*          → https://cloudinary.com/console (public HTTPS URLs for MMS)
# DATABASE_URL          → Render Postgres or local (optional; RAMP uses memory if missing)
# RAMP_PUBLIC_BASE_URL  → public salonx-web-v2 URL for SMS link /p/:token
# SALESMSG_ACCESS_TOKEN → app.salesmessage.com → Settings → Personal Access Tokens
# SALESMSG_TEAM_ID      → Swagger GET /teams → CODEMAN team numeric id
# SALESMSG_NUMBER_ID    → Swagger GET /numbers → (727) 615-2200 numeric id
# RAMP_SMS_MOCK         → true = console only, false = live SMS
#
# Swagger: https://app.salesmessage.com/api/docs
# Phone demo: ngrok http 5173 → set RAMP_PUBLIC_BASE_URL to https ngrok URL
# RAMP_PUBLIC_BASE_URL=http://localhost:5173

# Salesmsg outbound (live SMS + MMS image)
# RAMP_SMS_MOCK=true
# RAMP_SMS_PROVIDER=salesmsg
# SALESMSG_ACCESS_TOKEN=your_personal_access_token
# SALESMSG_TEAM_ID=main-inbox_253144
# SALESMSG_NUMBER_ID=67890

# OpenAI branded RAMP artifact generation (images/edits). Without key, mock passthrough is used.
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1

# salonx-web-v2 (production): VITE_V2_ADMIN_URL=https://demo-api-k8p3.onrender.com
# v2-admin: NEXT_PUBLIC_SALONX_API_ORIGIN=https://demo-api-k8p3.onrender.com
# Local dev: http://localhost:4000

# --- salonx-web-v2 (Vite dev) — same machine, proxy to demo-api ---
# In salonx-web-v2/.env: VITE_DEV_USE_DEMO_API=true
# Optional if demo-api is not on :4000: VITE_DEMO_API_PROXY_TARGET=http://127.0.0.1:4000
